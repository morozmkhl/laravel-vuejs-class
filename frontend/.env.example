# Пусто или полный URL бэкенда для production-сборки (например https://api.example.com)
VITE_API_URL=

# Только для vite dev: куда проксировать /api (должно совпадать с `php artisan serve`, по умолчанию порт 8000)
# Если при регистрации/логине в браузере 502 — Laravel не слушает этот URL: запустите
#   cd ../backend && php artisan serve
# или укажите сюда фактический host:port.
VITE_DEV_API_PROXY=http://127.0.0.1:8000

# Режим аутентификации: bearer (API токен в localStorage) или sanctum (cookie + CSRF, SPA)
# VITE_API_AUTH=bearer
# VITE_API_AUTH=sanctum

# Префикс маршрутов auth на бэкенде (логин, регистрация, /user, logout)
# VITE_AUTH_API_PREFIX=/api

# Ключ в localStorage для токена (только для bearer)
# VITE_AUTH_TOKEN_KEY=auth_token
